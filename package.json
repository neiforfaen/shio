{
  "name": "shio-ui",
  "version": "0.1.0",
  "bin": {
    "shio-ui": "dist/cli.js"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "check-types": "turbo run check-types",
    "gen:component": "turbo gen component",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/shadcn-ui",
    "clean": "git clean -fdx node_modules dist",
    "clean:all": "turbo run clean && pnpm clean && pnpm install",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@turbo/gen": "2.10.5",
    "@types/node": "26.1.1",
    "lefthook": "^2.1.10",
    "tsdown": "^0.22.9",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "ultracite": "latest"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  }
}
